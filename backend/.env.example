# ==============================================
# Secure Multi-Agent AI Platform — Backend ENV
# Copy this file to .env and fill in all values
# ==============================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/secure_ai_platform

# --- JWT (REQUIRED) ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# --- Native OAuth (REQUIRED for Dashboards) ---
# Create an OAuth App in Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Create an OAuth App in GitHub Developer Settings
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- Email OTP (Optional — OTP prints to console if blank) ---
# Use Gmail + App Password: myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# --- SMS OTP via Twilio (Optional — OTP prints to console if blank) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

# --- Auth0 (Optional — only for alternative Google Login button on Login page) ---
# Application settings from Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=https://api.secure-ai-platform.com

# --- LLM ---
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# --- Admin Panel ---
# These are the credentials for the /home/admin panel
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_SuperSecure123!

# --- CORS ---
FRONTEND_URL=http://localhost:5173
